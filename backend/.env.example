# Care-Connect-EMR backend environment variables (example).
# Copy to ".env" for local development. NEVER commit real secrets.
# In production (Render) these are injected as environment variables.

# --- Application ---
APP_ENV=development
# Comma-separated allowed CORS origins (the Vercel frontend origin in prod)
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- Database (async SQLAlchemy URL) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/careconnect
# Optional separate database for the test suite (transactional rollback)
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/careconnect_test

# --- Encryption (AES-256 key material; base64 or hex encoded) ---
EMR_ENCRYPTION_KEY=

# --- JWT sessions ---
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRES_HOURS=24

# --- SMTP / email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@careconnect.example

# --- WebRTC STUN/TURN ---
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
